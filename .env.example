# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_IDS=123456789
TELEGRAM_PROXY=
TELEGRAM_DISABLE_ENV_PROXY=true
TELEGRAM_CONNECT_TIMEOUT=5
TELEGRAM_READ_TIMEOUT=20
TELEGRAM_WRITE_TIMEOUT=20
TELEGRAM_POOL_TIMEOUT=5
TELEGRAM_BOOTSTRAP_RETRIES=-1
TELEGRAM_RESTART_BACKOFF_MIN=2
TELEGRAM_RESTART_BACKOFF_MAX=60
TELEGRAM_HEALTH_STALE_SECONDS=120

# Weixin Bot
WEIXIN_ENABLED=false
WEIXIN_ALLOWED_USER_IDS=
WEIXIN_CREDENTIALS_PATH=~/.weixin-bot/credentials.json

# Default model (litellm format)
DEFAULT_MODEL=openai/GLM-5.1
AVAILABLE_MODELS=openai/GLM-5.1,openai/GLM-5-Turbo

# LLM API Keys (fill in the ones you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_API_BASE=
# GLM (ZhiPu)
GLM_API_KEY=
GLM_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4

# Agent
WORKING_DIR=.
DEFAULT_TOOL_PRESET=coding
LLM_TIMEOUT=300
LLM_CHUNK_TIMEOUT=30
TURN_TIMEOUT=360
BASH_TIMEOUT=30
MAX_TURNS=20
SKILLS_DIR=skills
PROJECT_CONTEXT_FILE=PROJECT.md
USER_CONTEXT_FILE=USER.local.md
MEMORY_INDEX_FILE=MEMORY.md
MEMORY_DIR=memory
SESSION_STORAGE_DIR=data/sessions
SESSION_TTL_HOURS=72
SESSION_SUMMARY_TRIGGER_MESSAGES=18
SESSION_SUMMARY_RECENT_MESSAGES=12
SESSION_SUMMARY_MAX_CHARS=4000
WORKSPACE_STATE_DIR_NAME=.ragtag_crew
WORKSPACE_TMP_TTL_HOURS=168
WORKSPACE_SCRIPT_EXTENSIONS=.py,.ps1,.bat,.cmd,.sh,.js,.ts
EXTERNAL_TOOL_TIMEOUT=30
MCP_SERVERS_FILE=mcp_servers.local.json
OPENAPI_TOOLS_FILE=openapi_tools.local.json
OPENAPI_TIMEOUT=20
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=serper
WEB_SEARCH_API_URL=https://google.serper.dev/search
WEB_SEARCH_API_KEY=
WEB_SEARCH_TIMEOUT=15
WEB_SEARCH_MAX_RESULTS=5
EVERYTHING_ENABLED=false
EVERYTHING_COMMAND=es.exe
EVERYTHING_TIMEOUT=10
EVERYTHING_MAX_RESULTS=50
AGENT_BROWSER_ENABLED=false
AGENT_BROWSER_COMMAND=agent-browser
BROWSER_MODE_DEFAULT=isolated
BROWSER_PROFILE_DIR=data/browser/isolated
BROWSER_DEFAULT_TIMEOUT=30
BROWSER_HEADED=true
BROWSER_ALLOWED_DOMAINS=
BROWSER_ATTACHED_ENABLED=false
BROWSER_ATTACHED_REQUIRE_CONFIRMATION=true
BROWSER_ATTACHED_CDP_URL=
BROWSER_ATTACHED_AUTO_CONNECT=false

# Tools
TOOLS_CACHE_DIR=~/.ragtag_crew/bin
RG_COMMAND=rg
FD_ENABLED=false
FD_COMMAND=fd

# Logging
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3
